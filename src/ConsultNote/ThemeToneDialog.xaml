<Window x:Class="ConsultNote.ThemeToneDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="화면 톤 조정"
        Width="420"
        Height="310"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F6F5F1"
        FontFamily="Segoe UI, Malgun Gothic">
    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="화면 톤 조정"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#24211D" />
                <TextBlock Text="움직이면 바로 반영됩니다. 눈에 편한 지점에서 저장하세요."
                           Margin="0,5,0,0"
                           Foreground="#6F6A61" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,18,0,0">
                <TextBlock Text="밝기" Foreground="#24211D" />
                <Slider x:Name="BrightnessSlider"
                        Minimum="-18"
                        Maximum="10"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="Slider_ValueChanged" />

                <TextBlock Text="노란기" Foreground="#24211D" Margin="0,16,0,0" />
                <Slider x:Name="WarmthSlider"
                        Minimum="-20"
                        Maximum="10"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="Slider_ValueChanged" />

                <TextBlock Text="대비" Foreground="#24211D" Margin="0,16,0,0" />
                <Slider x:Name="ContrastSlider"
                        Minimum="-12"
                        Maximum="12"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="Slider_ValueChanged" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="초기화"
                        Width="78"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="ResetButton_Click" />
                <Button Content="취소"
                        Width="78"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="CancelButton_Click" />
                <Button Content="저장"
                        Width="78"
                        Height="34"
                        FontWeight="SemiBold"
                        Click="SaveButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
