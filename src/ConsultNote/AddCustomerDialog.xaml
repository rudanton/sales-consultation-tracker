<Window x:Class="ConsultNote.AddCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="고객 추가"
        Width="420"
        Height="310"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI, Malgun Gothic">
    <Window.Resources>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="#D7DEE8"
            BorderThickness="1"
            CornerRadius="6"
            Padding="18"
            Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="고객 추가" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="이름과 연락처를 먼저 등록한 뒤 상세 상담 내용을 채웁니다."
                           Style="{StaticResource MutedText}"
                           Margin="0,3,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock Text="이름" Style="{StaticResource MutedText}" />
                <TextBox x:Name="CustomerNameTextBox"
                         Padding="8,5"
                         Margin="0,5,0,10"
                         TextChanged="CustomerNameTextBox_TextChanged" />

                <TextBlock Text="연락처" Style="{StaticResource MutedText}" />
                <TextBox x:Name="CustomerPhoneTextBox"
                         Padding="8,5"
                         Margin="0,5,0,10"
                         LostFocus="CustomerPhoneTextBox_LostFocus" />

                <TextBlock Text="관심 차량" Style="{StaticResource MutedText}" />
                <ComboBox x:Name="CustomerVehicleComboBox"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          ItemsSource="{Binding CustomerVehicleNames}"
                          Padding="4,3"
                          Margin="0,5,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="취소"
                        Style="{StaticResource DialogButton}"
                        Margin="0,0,8,0"
                        IsCancel="True" />
                <Button x:Name="SaveButton"
                        Content="저장"
                        Style="{StaticResource PrimaryButton}"
                        IsDefault="True"
                        IsEnabled="False"
                        Click="SaveButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
