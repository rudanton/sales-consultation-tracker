<Window x:Class="ConsultNote.AddCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="고객 추가"
        Width="420"
        Height="330"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI, Malgun Gothic">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}" />
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ControlFocusBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource ThemeBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="18"
            Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="고객 추가" FontSize="18" FontWeight="Bold" />
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock Text="이름" Style="{StaticResource MutedText}" />
                <TextBox x:Name="CustomerNameTextBox"
                         Padding="8,5"
                         Margin="0,5,0,10"
                         TextChanged="CustomerNameTextBox_TextChanged" />

                <TextBlock Text="연락처" Style="{StaticResource MutedText}" />
                <TextBox x:Name="CustomerPhoneTextBox"
                         Padding="8,5"
                         Margin="0,5,0,0"
                         LostFocus="CustomerPhoneTextBox_LostFocus" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="취소"
                        Style="{StaticResource DialogButton}"
                        Margin="0,0,8,0"
                        IsCancel="True" />
                <Button x:Name="SaveButton"
                        Content="저장"
                        Style="{StaticResource PrimaryButton}"
                        IsDefault="True"
                        IsEnabled="False"
                        Click="SaveButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
