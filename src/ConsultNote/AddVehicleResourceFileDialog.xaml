<Window x:Class="ConsultNote.AddVehicleResourceFileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="차량 자료 추가"
        Width="560"
        Height="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI, Malgun Gothic">
    <Window.Resources>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="#D7DEE8"
            BorderThickness="1"
            CornerRadius="6"
            Padding="18"
            Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,14">
                <TextBlock x:Name="TitleTextBlock" Text="차량 자료 추가" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="공용 견적서, 차량 설명서, 홍보용 자료를 차량 자료 폴더에 저장합니다."
                           Style="{StaticResource MutedText}"
                           Margin="0,3,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock x:Name="FileLabelTextBlock" Text="파일" Style="{StaticResource MutedText}" />
                <Grid x:Name="FilePickerPanel" Margin="0,5,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FilePathTextBox" Padding="8,5" IsReadOnly="True" />
                    <Button Grid.Column="2"
                            Content="찾기"
                            Style="{StaticResource DialogButton}"
                            Click="BrowseButton_Click" />
                </Grid>

                <TextBlock Text="차량" Style="{StaticResource MutedText}" />
                <Grid Margin="0,5,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="VehicleBrandComboBox"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              SelectionChanged="VehicleBrandComboBox_SelectionChanged" />
                    <ComboBox x:Name="VehicleNameComboBox"
                              Grid.Column="2"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              SelectionChanged="VehicleNameComboBox_SelectionChanged" />
                    <ComboBox x:Name="FuelTypeComboBox"
                              Grid.Column="4"
                              IsEditable="True"
                              IsTextSearchEnabled="True" />
                </Grid>

                <TextBlock Text="자료 유형" Style="{StaticResource MutedText}" />
                <ComboBox x:Name="FileTypeComboBox"
                          Margin="0,5,0,10"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          StaysOpenOnEdit="True"
                          SelectionChanged="FileTypeComboBox_SelectionChanged" />

                <StackPanel x:Name="CustomFileTypePanel" Visibility="Collapsed" Margin="0,0,0,10">
                    <TextBlock Text="기타 자료 유형명" Style="{StaticResource MutedText}" />
                    <TextBox x:Name="CustomFileTypeTextBox" Padding="8,5" Margin="0,5,0,0" />
                </StackPanel>

                <TextBlock Text="자료 순서(자동)" Style="{StaticResource MutedText}" />
                <TextBox x:Name="FileOrderTextBox"
                         Text="1"
                         IsReadOnly="True"
                         Focusable="False"
                         Padding="8,5"
                         Margin="0,5,0,10" />

                <TextBlock Text="메모" Style="{StaticResource MutedText}" />
                <TextBox x:Name="MemoTextBox"
                         Padding="8,5"
                         Margin="0,5,0,0"
                         Height="86"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="취소"
                        Style="{StaticResource DialogButton}"
                        Margin="0,0,8,0"
                        IsCancel="True" />
                <Button Content="저장"
                        Style="{StaticResource PrimaryButton}"
                        IsDefault="True"
                        Click="SaveButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
