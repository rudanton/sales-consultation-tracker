<Window x:Class="ConsultNote.VehicleManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="차량 관리"
        Width="760"
        Height="520"
        MinWidth="720"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI, Malgun Gothic">
    <Window.Resources>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="#D7DEE8"
            BorderThickness="1"
            CornerRadius="6"
            Padding="16"
            Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="차량 관리" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="제조사, 차량명, 유종을 관리합니다. 비활성 차량은 입력 목록에서 숨깁니다."
                               Style="{StaticResource MutedText}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="신규"
                        Style="{StaticResource PrimaryButton}"
                        VerticalAlignment="Top"
                        Click="NewButton_Click" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10">
                    <ListBox x:Name="VehiclesListBox"
                             ItemsSource="{Binding Vehicles}"
                             SelectionChanged="VehiclesListBox_SelectionChanged"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ActiveText}"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding Summary}"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,3,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Border Grid.Column="2"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="차량 정보" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <StackPanel Grid.Row="1" Margin="0,0,0,10">
                            <TextBlock Text="제조사" Style="{StaticResource MutedText}" />
                            <TextBox x:Name="BrandTextBox" Padding="8,5" Margin="0,5,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,0,0,10">
                            <TextBlock Text="차량명" Style="{StaticResource MutedText}" />
                            <TextBox x:Name="NameTextBox" Padding="8,5" Margin="0,5,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Row="3" Margin="0,0,0,10">
                            <TextBlock Text="유종" Style="{StaticResource MutedText}" />
                            <TextBox x:Name="FuelTypesTextBox" Padding="8,5" Margin="0,5,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Row="4">
                            <TextBlock Text="메모" Style="{StaticResource MutedText}" />
                            <TextBox x:Name="MemoTextBox"
                                     Padding="8,5"
                                     Margin="0,5,0,0"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">
                <Button x:Name="ToggleActiveButton"
                        Content="비활성화"
                        Style="{StaticResource DialogButton}"
                        Margin="0,0,8,0"
                        Click="ToggleActiveButton_Click" />
                <Button Content="저장"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,8,0"
                        Click="SaveButton_Click" />
                <Button Content="닫기"
                        Style="{StaticResource DialogButton}"
                        IsCancel="True" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
