<Window x:Class="ConsultNote.DiscardCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="폐기 사유"
        Width="420"
        Height="230"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI, Malgun Gothic">
    <Border Background="#FFFFFF"
            BorderBrush="#D7DEE8"
            BorderThickness="1"
            CornerRadius="6"
            Padding="18"
            Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="폐기 사유" FontSize="18" FontWeight="Bold" />

            <TextBox x:Name="ReasonTextBox"
                     Grid.Row="1"
                     Margin="0,12,0,0"
                     Padding="8,6"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">
                <Button Content="취소"
                        MinWidth="76"
                        MinHeight="32"
                        Margin="0,0,8,0"
                        IsCancel="True" />
                <Button Content="폐기"
                        MinWidth="76"
                        MinHeight="32"
                        IsDefault="True"
                        Click="DiscardButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
