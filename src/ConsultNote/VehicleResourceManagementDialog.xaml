<Window x:Class="ConsultNote.VehicleResourceManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="차량별 자료"
        Width="820"
        Height="620"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI, Malgun Gothic"
        AllowDrop="True"
        DragOver="VehicleResourceDialog_DragOver"
        Drop="VehicleResourceDialog_Drop">
    <Window.Resources>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="FileItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <DataTemplate x:Key="VehicleResourceTemplate">
            <Border Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding VehicleSummary}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,3,0,0" />
                        <TextBlock Text="{Binding Summary}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding FileType}"
                               Style="{StaticResource MutedText}"
                               Margin="12,0,0,0" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="#D7DEE8"
            BorderThickness="1"
            CornerRadius="6"
            Padding="16"
            Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="차량별 자료" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="차량별 견적서, 설명서, 홍보용 자료를 관리합니다."
                               Style="{StaticResource MutedText}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="추가"
                        Style="{StaticResource PrimaryButton}"
                        Click="AddButton_Click" />
                <Button Grid.Column="3"
                        Content="수정"
                        Style="{StaticResource DialogButton}"
                        Click="EditButton_Click" />
                <Button Grid.Column="5"
                        Content="삭제"
                        Style="{StaticResource DialogButton}"
                        Click="DeleteButton_Click" />
                <Button Grid.Column="7"
                        Content="폴더"
                        Style="{StaticResource DialogButton}"
                        Click="OpenFolderButton_Click" />
            </Grid>

            <ListBox x:Name="VehicleResourceListBox"
                     Grid.Row="1"
                     ItemsSource="{Binding ResourceFiles}"
                     SelectedItem="{Binding SelectedResource}"
                     ItemTemplate="{StaticResource VehicleResourceTemplate}"
                     ItemContainerStyle="{StaticResource FileItem}"
                     BorderThickness="0"
                     Background="Transparent"
                     MouseDoubleClick="VehicleResourceListBox_MouseDoubleClick"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <TextBlock Text="파일을 창 안으로 드롭해서 추가할 수 있습니다."
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <Button Content="닫기"
                        Style="{StaticResource DialogButton}"
                        IsCancel="True" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
