<Window x:Class="ConsultNote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Consult Note"
        MinHeight="810"
        MinWidth="1440"
        Height="810"
        Width="1440"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI, Malgun Gothic">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}" />
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ProminentToggleButton" TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}" />
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavoriteToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}" />
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
                    <Setter Property="Background" Value="{StaticResource ControlFocusBrush}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Background" Value="{StaticResource ControlHoverBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarRailButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}" />
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="CustomerSortComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0,4,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomerItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FileItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <DataTemplate x:Key="CustomerTemplate">
            <Border BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                        <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter Property="Background" Value="{StaticResource SelectionBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource SelectionBorderBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="★"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="Bold"
                                       Margin="0,0,5,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" />
                            <TextBlock Text="{Binding StatusText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="8,2,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding RecentText}"
                                   Style="{StaticResource MutedText}" />
                    </Grid>
                    <TextBlock Margin="0,5,0,0" TextWrapping="Wrap">
                        <Run Text="{Binding PhoneNumber}" />
                        <Run Text=" · " />
                        <Run Text="{Binding CustomerType}" />
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource MutedText}"
                               Text="{Binding VehicleMemoDetail}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ConsultationLogTemplate">
            <Border BorderBrush="{StaticResource ThemeBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="0,0,0,12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CreatedAtText}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding StatusText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="8,0,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="수정"
                                    Tag="{Binding Id}"
                                    MinHeight="23"
                                    Padding="8,0"
                                    Margin="0,0,6,0"
                                    Click="EditConsultationLogButton_Click" />
                            <Button Content="삭제"
                                    Tag="{Binding Id}"
                                    MinHeight="23"
                                    Padding="8,0"
                                    Click="DeleteConsultationLogButton_Click" />
                        </StackPanel>
                    </Grid>
                    <TextBox Text="{Binding Content}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FileTemplate">
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource ThemeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Summary}"
                               Style="{StaticResource MutedText}"
                               Margin="0,3,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="RootGrid" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource Panel}"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,18,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Consult Note" FontSize="21" FontWeight="Bold" />
                        <TextBlock x:Name="AppVersionTextBlock"
                                   Style="{StaticResource MutedText}"
                                   Margin="8,7,0,0" />
                    </StackPanel>
                    <TextBlock Text="상담 기록과 견적 파일을 빠르게 찾는 개인 작업대"
                               Style="{StaticResource MutedText}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchTextBox"
                             Height="38"
                             Padding="12,8"
                             FontSize="14"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{StaticResource TextPrimaryBrush}" />
                    <Button Grid.Column="2"
                            Content="초기화"
                            Style="{StaticResource ToolbarButton}"
                            Click="ClearSearchButton_Click" />
                </Grid>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <Button Content="고객 추가"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"
                            Click="AddCustomerButton_Click" />
                    <Button Content="차종 목록"
                            Style="{StaticResource ToolbarButton}"
                            Margin="0,0,8,0"
                            Click="VehicleManagementButton_Click" />
                    <Button Content="차량별 자료"
                            Style="{StaticResource ToolbarButton}"
                            Margin="0,0,8,0"
                            Click="VehicleResourceManagementButton_Click" />
                    <ToggleButton x:Name="CloseToTrayToggleButton"
                                  Content="트레이 끔"
                                  Style="{StaticResource ProminentToggleButton}"
                                  IsChecked="False"
                                  Height="34"
                                  MinHeight="34"
                                  Margin="0,0,8,0"
                                  Checked="CloseToTrayToggleButton_Changed"
                                  Unchecked="CloseToTrayToggleButton_Changed" />
                    <Button Content="업데이트 확인"
                            Style="{StaticResource ToolbarButton}"
                            Click="CheckUpdateButton_Click" />
                </StackPanel>

                <Border Grid.Row="1"
                        Grid.ColumnSpan="3"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource ThemeBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,7"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding DashboardSummary}"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding DashboardStatusSummary}"
                                   Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition x:Name="SidebarColumn" Width="94" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Panel}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="86" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding CustomerListTitle}" Style="{StaticResource SectionTitle}" />
                            <CheckBox Content="폐기 목록"
                                      IsChecked="{Binding ShowDiscardedCustomers}"
                                      Margin="0,-4,0,0" />
                        </StackPanel>
                        <ComboBox Grid.Column="2"
                                  Style="{StaticResource CustomerSortComboBox}"
                                  ItemsSource="{Binding CustomerStatusFilterOptions}"
                                  SelectedItem="{Binding SelectedCustomerStatusFilter}" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="2"
                                  Style="{StaticResource CustomerSortComboBox}"
                                  ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SelectedSortOption}" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="4"
                                  Style="{StaticResource CustomerSortComboBox}"
                                  ItemsSource="{Binding SortDirections}"
                                  SelectedItem="{Binding SelectedSortDirection}" />
                    </Grid>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Customers}"
                             SelectedItem="{Binding SelectedCustomer}"
                             ItemTemplate="{StaticResource CustomerTemplate}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource CustomerItem}" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Panel}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedCustomer.Name}" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="{Binding SelectedCustomer.StatusText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="14"
                                           Margin="10,9,0,0" />
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedCustomer.HeaderDetail}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <Button Content="연락처 복사"
                                    Height="28"
                                    MinHeight="28"
                                    Padding="10,0"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource ToolbarButton}"
                                    Click="CopyCustomerPhoneButton_Click" />
                            <ToggleButton x:Name="FavoriteToggleButton"
                                          Content="★"
                                          ToolTip="즐겨찾기"
                                          Margin="0,0,8,0"
                                          Style="{StaticResource FavoriteToggleButtonStyle}"
                                          IsChecked="{Binding SelectedCustomer.IsFavorite}"
                                          Click="FavoriteToggleButton_Click" />
                            <Button Content="폐기"
                                    x:Name="DiscardCustomerButton"
                                    Height="28"
                                    MinHeight="28"
                                    Padding="10,0"
                                    Click="DiscardCustomerButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectedCustomerDiscarded}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="복구"
                                    Height="28"
                                    MinHeight="28"
                                    Padding="10,0"
                                    Click="RestoreCustomerButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectedCustomerDiscarded}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border x:Name="BasicInfoPanel"
                            Grid.Row="1"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource ThemeBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="2.4*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="이름" Style="{StaticResource MutedText}" />
                                <TextBox Text="{Binding CustomerNameInput, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,4"
                                         Margin="0,5,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0">
                                <TextBlock Text="연락처" Style="{StaticResource MutedText}" />
                                <TextBox x:Name="CustomerPhoneTextBox"
                                         Text="{Binding CustomerPhoneInput, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,4"
                                         Margin="0,5,0,0"
                                         LostFocus="CustomerPhoneTextBox_LostFocus" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="8,0">
                                <TextBlock Text="메모" Style="{StaticResource MutedText}" />
                                <TextBox Text="{Binding CustomerMemoInput, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,4"
                                         Margin="0,5,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="330" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="ConditionFormPanel"
                                Grid.Column="0"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource ThemeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="상담 조건 양식" FontWeight="SemiBold" Margin="0,0,0,4" />

                                <ScrollViewer x:Name="ConditionFormScrollViewer"
                                              Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              CanContentScroll="False"
                                              Margin="2,0">
                                <StackPanel Margin="0,0,6,0">
                                            <StackPanel Margin="0,0,0,1">
                                                <TextBlock Text="렌트/리스" Style="{StaticResource MutedText}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                                    <RadioButton x:Name="RentRadioButton" Content="렌트" GroupName="ContractType" Margin="0,0,14,0" />
                                                    <RadioButton x:Name="LeaseRadioButton" Content="리스" GroupName="ContractType" />
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,1">
                                                <TextBlock Text="차량스팩" Style="{StaticResource MutedText}" />
                                                <Grid Margin="0,1,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="76" />
                                                        <ColumnDefinition Width="6" />
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="6" />
                                                        <ColumnDefinition Width="*" MinWidth="96" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox x:Name="VehicleBrandComboBox"
                                                              IsEditable="False"
                                                              IsTextSearchEnabled="True"
                                                              ItemsSource="{Binding VehicleBrands}"
                                                              SelectedItem="{Binding SelectedVehicleBrand}" />
                                                    <ComboBox x:Name="VehicleNameComboBox"
                                                              Grid.Column="2"
                                                              IsEditable="False"
                                                              IsTextSearchEnabled="True"
                                                              ItemsSource="{Binding VehicleNames}"
                                                              SelectedItem="{Binding SelectedVehicleName}"
                                                              SelectionChanged="VehicleNameComboBox_SelectionChanged" />
                                                    <ComboBox x:Name="FuelTypeComboBox"
                                                              Grid.Column="4"
                                                              IsEditable="False"
                                                              IsTextSearchEnabled="True"
                                                              ItemsSource="{Binding FuelTypes}"
                                                              SelectedItem="{Binding SelectedFuelType}" />
                                                </Grid>
                                                    <TextBox x:Name="VehicleDetailTextBox"
                                                             Text="상세 옵션"
                                                             Padding="8,3"
                                                             Foreground="{StaticResource TextSecondaryBrush}"
                                                             Margin="0,2,0,0"
                                                             GotFocus="PlaceholderTextBox_GotFocus"
                                                             LostFocus="PlaceholderTextBox_LostFocus" />
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,1">
                                                <TextBlock Text="계약기간" Style="{StaticResource MutedText}" />
                                                <ComboBox x:Name="ContractPeriodComboBox" Margin="0,1,0,0">
                                                    <ComboBoxItem Content="단기" />
                                                    <ComboBoxItem Content="36개월" />
                                                    <ComboBoxItem Content="48개월" />
                                                    <ComboBoxItem Content="60개월" />
                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,1">
                                                <TextBlock Text="주행거리" Style="{StaticResource MutedText}" />
                                                <Grid Margin="0,1,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox x:Name="MileageComboBox"
                                                              SelectionChanged="MileageComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="1만km" />
                                                        <ComboBoxItem Content="1.5만km" />
                                                        <ComboBoxItem Content="2만km" />
                                                        <ComboBoxItem Content="2.5만km" />
                                                        <ComboBoxItem Content="3만km" />
                                                        <ComboBoxItem Content="3.5만km" />
                                                        <ComboBoxItem Content="4만km" />
                                                        <ComboBoxItem Content="4.5만km" />
                                                        <ComboBoxItem Content="5만km" />
                                                        <ComboBoxItem Content="무제한" />
                                                        <ComboBoxItem Content="직접입력" />
                                                    </ComboBox>
                                                    <TextBox x:Name="MileageCustomTextBox"
                                                             Grid.Column="2"
                                                             Text=""
                                                             IsEnabled="False"
                                                             Padding="8,3"
                                                             Foreground="{StaticResource TextSecondaryBrush}"
                                                             ToolTip="직접입력 선택 시 0~5 사이, 소수점 1자리까지 입력"
                                                             GotFocus="MileageCustomTextBox_GotFocus"
                                                             LostFocus="MileageCustomTextBox_LostFocus" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,1">
                                                <TextBlock Text="인도지역" Style="{StaticResource MutedText}" />
                                                <Grid Margin="0,1,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox x:Name="DeliveryRegionComboBox">
                                                        <ComboBoxItem Content="미정" />
                                                        <ComboBoxItem Content="서울/경기/인천" />
                                                        <ComboBoxItem Content="부산/울산/경남" />
                                                        <ComboBoxItem Content="대구/경북" />
                                                        <ComboBoxItem Content="광주/전남" />
                                                        <ComboBoxItem Content="전북" />
                                                        <ComboBoxItem Content="대전/세종/충남" />
                                                        <ComboBoxItem Content="충북" />
                                                        <ComboBoxItem Content="강원" />
                                                        <ComboBoxItem Content="제주" />
                                                    </ComboBox>
                                                    <TextBox x:Name="DeliveryRegionDetailTextBox"
                                                             Grid.Column="2"
                                                             Text="상세 지역"
                                                             Padding="8,3"
                                                             Foreground="{StaticResource TextSecondaryBrush}"
                                                             GotFocus="PlaceholderTextBox_GotFocus"
                                                             LostFocus="PlaceholderTextBox_LostFocus" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,1">
                                                <TextBlock Text="초기비용" Style="{StaticResource MutedText}" />
                                                <Grid Margin="0,1,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox x:Name="NoInitialCostCheckBox" Content="없음" VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="선납금" Style="{StaticResource MutedText}" />
                                                        <TextBox x:Name="PrepaymentTextBox"
                                                                 Padding="8,3"
                                                                 Margin="0,1,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="보증금" Style="{StaticResource MutedText}" />
                                                        <TextBox x:Name="DepositTextBox"
                                                                 Padding="8,3"
                                                                 Margin="0,1,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,1">
                                                <TextBlock Text="명의형태" Style="{StaticResource MutedText}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                                    <RadioButton x:Name="PersonalOwnerRadioButton" Content="개인" GroupName="OwnerType" Margin="0,0,12,0" Checked="OwnerTypeRadioButton_Checked" />
                                                    <RadioButton x:Name="SoleProprietorOwnerRadioButton" Content="개인사업자" GroupName="OwnerType" Margin="0,0,12,0" Checked="OwnerTypeRadioButton_Checked" />
                                                    <RadioButton x:Name="CorporateOwnerRadioButton" Content="법인사업자" GroupName="OwnerType" Checked="OwnerTypeRadioButton_Checked" />
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,1">
                                                <TextBlock Text="사업업력 / 운전면허" Style="{StaticResource MutedText}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                                    <ToggleButton x:Name="BusinessExperienceToggleButton"
                                                                  Content="사업업력 1년 이상"
                                                                  Style="{StaticResource ProminentToggleButton}"
                                                                  Margin="0,0,8,0" />
                                                    <ToggleButton x:Name="DriverLicenseToggleButton"
                                                                  Content="운전면허 1년 이상"
                                                                  Style="{StaticResource ProminentToggleButton}"
                                                                  />
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,1">
                                                <TextBlock Text="실운전자" Style="{StaticResource MutedText}" />
                                                <TextBox x:Name="ActualDriverTextBox" Padding="8,2" Margin="0,1,0,0" />
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,1">
                                                <TextBlock Text="보험연령" Style="{StaticResource MutedText}" />
                                                <ComboBox x:Name="InsuranceAgeComboBox" Margin="0,1,0,0">
                                                    <ComboBoxItem Content="21세 이상" />
                                                    <ComboBoxItem Content="26세 이상" />
                                                    <ComboBoxItem Content="35세 이상" />
                                                    <ComboBoxItem Content="70세 이상" />
                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,1">
                                                <TextBlock Text="신용상태" Style="{StaticResource MutedText}" />
                                                <TextBox x:Name="CreditStatusTextBox" Padding="8,2" Margin="0,1,0,0" />
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,1">
                                                <TextBlock Text="특이사항" Style="{StaticResource MutedText}" />
                                                <TextBox x:Name="SpecialNoteTextBox" Padding="8,2" Margin="0,1,0,0" />
                                            </StackPanel>

                                            <StackPanel x:Name="ContractHolderPanel" Margin="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="명의자 정보" Style="{StaticResource MutedText}" />
                                                    <CheckBox x:Name="ContractHolderSameAsCustomerCheckBox"
                                                              Grid.Column="1"
                                                              Content="고객과 동일"
                                                              Checked="ContractHolderSameAsCustomerCheckBox_Changed"
                                                              Unchecked="ContractHolderSameAsCustomerCheckBox_Changed" />
                                                </Grid>
                                                <Grid Margin="0,1,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="ContractHolderNameTextBox"
                                                             Padding="8,3"
                                                             ToolTip="명의자 이름" />
                                                    <TextBox x:Name="ContractHolderPhoneTextBox"
                                                             Grid.Column="2"
                                                             Padding="8,3"
                                                             ToolTip="명의자 연락처"
                                                             LostFocus="CustomerPhoneTextBox_LostFocus" />
                                                </Grid>
                                            </StackPanel>
                                </StackPanel>
                                </ScrollViewer>

                                <Grid Grid.Row="2"
                                      Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="1.45*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="차량별 자료"
                                            ToolTip="선택한 차량명으로 기존 상담과 차량별 자료를 검색합니다."
                                            Style="{StaticResource ToolbarButton}"
                                            Click="SimilarConditionSearchButton_Click" />
                                    <Button Grid.Column="2"
                                            Content="복사하기"
                                            Style="{StaticResource ToolbarButton}"
                                            Click="ConsultationExportButton_Click" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource ThemeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="상담 기록" Style="{StaticResource SectionTitle}" />
                                    <Button Grid.Column="1"
                                            Content="전체 내보내기"
                                            Style="{StaticResource ToolbarButton}"
                                            Height="28"
                                            MinHeight="28"
                                            Padding="10,0"
                                            Click="ConsultationHistoryExportButton_Click" />
                                </Grid>
                                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="상태" Style="{StaticResource MutedText}" />
                                            <ComboBox ItemsSource="{Binding CustomerStatusOptions}"
                                                      SelectedItem="{Binding SelectedCustomerStatus}"
                                                      Height="28"
                                                      Margin="0,5,0,0" />
                                        </StackPanel>
                                        <Button x:Name="ConsultationLogSaveButton"
                                                Grid.Column="2"
                                                Content="저장"
                                                Style="{StaticResource PrimaryButton}"
                                                Height="27"
                                                MinHeight="27"
                                                MinWidth="84"
                                                Padding="10,0"
                                                VerticalAlignment="Bottom"
                                                Click="ConsultationLogSaveButton_Click" />
                                    </Grid>
                                    <TextBox x:Name="ConsultationContentTextBox"
                                             MinHeight="72"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             HorizontalScrollBarVisibility="Disabled"
                                             VerticalScrollBarVisibility="Auto"
                                             Padding="8,6"
                                             PreviewKeyDown="ConsultationContentTextBox_PreviewKeyDown" />
                                </StackPanel>
                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="상담 기록"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,0,0,8" />
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding SelectedCustomer.ConsultationLogs}"
                                                      ItemTemplate="{StaticResource ConsultationLogTemplate}" />
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="4">
                <Border x:Name="SidebarPanel"
                        Style="{StaticResource Panel}"
                        Padding="14"
                        Visibility="Collapsed"
                        AllowDrop="True"
                        DragOver="CustomerFileDropArea_DragOver"
                        Drop="CustomerFileDropArea_Drop">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="190" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="파일" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="파일을 이 영역에 드롭해서 추가할 수 있습니다."
                                           Style="{StaticResource MutedText}"
                                           Margin="0,-6,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="추가"
                                    Style="{StaticResource ToolbarButton}"
                                    Height="28"
                                    MinHeight="28"
                                    Padding="9,0"
                                    VerticalAlignment="Top"
                                    Click="AddCustomerFileButton_Click" />
                            <Button Grid.Column="3"
                                    Content="삭제"
                                    Style="{StaticResource ToolbarButton}"
                                    Height="28"
                                    MinHeight="28"
                                    Padding="9,0"
                                    VerticalAlignment="Top"
                                    Click="DeleteCustomerFileButton_Click" />
                            <Button Grid.Column="5"
                                    Content="폴더"
                                    Style="{StaticResource ToolbarButton}"
                                    Height="28"
                                    MinHeight="28"
                                    Padding="9,0"
                                    VerticalAlignment="Top"
                                    Click="OpenCustomerFilesFolderButton_Click" />
                            <Button x:Name="SidebarToggleButton"
                                    Grid.Column="7"
                                    Content="사이드바 접기"
                                    ToolTip="파일 사이드바 접기"
                                    Style="{StaticResource ToolbarButton}"
                                    Height="28"
                                    MinHeight="28"
                                    Padding="9,0"
                                    VerticalAlignment="Top"
                                    Click="SidebarToggleButton_Click" />
                        </Grid>

                        <Border Grid.Row="1"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource ThemeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Background="{StaticResource ControlBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MouseLeftButtonDown="SelectedFilePreview_MouseLeftButtonDown">
                                    <Grid>
                                        <Image x:Name="SelectedFilePreviewImage"
                                               Stretch="Uniform"
                                               Visibility="Collapsed" />
                                        <TextBlock x:Name="SelectedFilePreviewLabel"
                                                   Text="{Binding SelectedFile.PreviewLabel}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding SelectedFile.PreviewTitle}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedFile.PreviewMeta}"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="116" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="파일 목록" Style="{StaticResource SectionTitle}" />
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="FileTypeFilterComboBox"
                                          Height="30"
                                          SelectionChanged="FileListOption_SelectionChanged" />
                                <ComboBox x:Name="FileSortComboBox"
                                          Grid.Column="2"
                                          Height="30"
                                          SelectionChanged="FileListOption_SelectionChanged" />
                            </Grid>
                            <ListBox x:Name="FileListBox"
                                     Grid.Row="2"
                                     ItemsSource="{Binding SelectedCustomer.Files}"
                                     SelectedItem="{Binding SelectedFile}"
                                     ItemTemplate="{StaticResource FileTemplate}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     MouseDoubleClick="FileListBox_MouseDoubleClick"
                                     ItemContainerStyle="{StaticResource FileItem}" />
                            <TextBlock x:Name="ReferenceEstimateTitleTextBlock"
                                       Grid.Row="3"
                                       Text="차량별 자료"
                                       Style="{StaticResource SectionTitle}"
                                       Margin="0,12,0,6" />
                            <ListBox x:Name="ReferenceEstimateListBox"
                                     Grid.Row="4"
                                     ItemTemplate="{StaticResource FileTemplate}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     MouseDoubleClick="ReferenceEstimateListBox_MouseDoubleClick"
                                     ItemContainerStyle="{StaticResource FileItem}" />
                        </Grid>
                    </Grid>
                    </ScrollViewer>
                </Border>

                <Border x:Name="SidebarCollapsedPanel"
                        Style="{StaticResource Panel}"
                        Padding="10"
                        Visibility="Visible">
                    <Button x:Name="SidebarCollapsedToggleButton"
                            Content="파일 ›"
                            ToolTip="파일 열기"
                            Style="{StaticResource ToolbarButton}"
                            Click="SidebarToggleButton_Click" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>

