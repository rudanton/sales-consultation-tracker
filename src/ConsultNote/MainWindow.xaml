<Window x:Class="ConsultNote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Consult Note"
        MinHeight="720"
        MinWidth="1180"
        Height="780"
        Width="1320"
        Background="#F5F7FA"
        FontFamily="Segoe UI, Malgun Gothic">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D7DEE8" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#172033" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="SoftAccentBrush" Color="#EAF1FF" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="CustomerItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="FileItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource Panel}"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,18,0">
                    <TextBlock Text="Consult Note" FontSize="21" FontWeight="Bold" />
                    <TextBlock Text="상담 기록과 견적 파일을 빠르게 찾는 개인 작업대"
                               Style="{StaticResource MutedText}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <TextBox Height="38"
                             Padding="12,8"
                             FontSize="14"
                             Text="K5 / 김민수 / 010 / 월 50"
                             Foreground="#334155" />
                </Grid>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <Button Content="고객 추가"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" />
                    <Button x:Name="SidebarToggleButton"
                            Content="파일 닫기"
                            Style="{StaticResource ToolbarButton}"
                            Click="SidebarToggleButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition x:Name="SidebarColumn" Width="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Panel}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="86" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="고객 목록" Style="{StaticResource SectionTitle}" />
                        <ComboBox Grid.Column="1" Height="30" SelectedIndex="0">
                            <ComboBoxItem Content="등록순" />
                            <ComboBoxItem Content="최근 상담순" />
                            <ComboBoxItem Content="상태순" />
                        </ComboBox>
                        <ComboBox Grid.Column="3" Height="30" SelectedIndex="1">
                            <ComboBoxItem Content="오름" />
                            <ComboBoxItem Content="내림" />
                        </ComboBox>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="빠른 검색 결과" FontWeight="SemiBold" />
                            <TextBlock Text="K5 조건과 월 50만원 전후 견적을 가진 고객 3명"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="2"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectedIndex="0"
                             ItemContainerStyle="{StaticResource CustomerItem}">
                        <ListBoxItem>
                            <Border Background="{StaticResource SoftAccentBrush}"
                                    BorderBrush="#BBD1FF"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="김민수" FontWeight="Bold" FontSize="15" />
                                        <TextBlock Text="최근 10:30"
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                    <TextBlock Text="상담중 · 010-1234-5678 · K5 하이브리드"
                                               Margin="0,5,0,0" />
                                    <TextBlock Text="월 50만원 이하 희망, 배우자와 상의 예정"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                        <ListBoxItem>
                            <Border Background="#FFFFFF"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="박지훈" FontWeight="Bold" FontSize="15" />
                                        <TextBlock Text="어제"
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                    <TextBlock Text="부재 · 3일 경과 · 010-7788-9012 · K5 / 쏘나타 비교"
                                               Margin="0,5,0,0" />
                                    <TextBlock Text="초기비용 낮은 조건 선호"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                        <ListBoxItem>
                            <Border Background="#FFFFFF"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="이서연" FontWeight="Bold" FontSize="15" />
                                        <TextBlock Text="07-05"
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                    <TextBlock Text="심사 · 010-4567-2200 · 아반떼 / K5 문의"
                                               Margin="0,5,0,0" />
                                    <TextBlock Text="사업자등록증 확인 필요"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Panel}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="김민수" FontSize="24" FontWeight="Bold" />
                            <TextBlock Text="상담중 · 010-1234-5678 · K5 하이브리드 · 회사 DB #A-1042"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="정보 수정"
                                Style="{StaticResource ToolbarButton}"
                                VerticalAlignment="Top" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#F8FAFC" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="최근 상담" Style="{StaticResource MutedText}" />
                                <TextBlock Text="2026-07-07 10:30" FontWeight="SemiBold" Margin="0,3,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="6" Padding="12" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="관심 조건" Style="{StaticResource MutedText}" />
                                <TextBlock Text="월 50만원 이하" FontWeight="SemiBold" Margin="0,3,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#F8FAFC" CornerRadius="6" Padding="12" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="참고 후보" Style="{StaticResource MutedText}" />
                                <TextBlock Text="K5 유사 견적 2건" FontWeight="SemiBold" Margin="0,3,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#FBFCFE"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="86" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="새 상담 기록" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBox Grid.Row="1"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="10"
                                         Text="K5 견적 안내 후 배우자와 상의 예정. 유사 조건 견적 다시 확인 필요." />
                                <Button Grid.Row="2"
                                        Content="기록 추가"
                                        Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Right"
                                        Margin="0,10,0,0" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="#FFFFFF"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="상담 기록 쓰레드" Style="{StaticResource SectionTitle}" />
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="2026-07-07 10:30" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="K5 문의. 월 50만원 이하 희망. 배우자와 상의 후 재연락 예정."
                                                           Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="2026-07-06 16:15" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="초기비용 낮은 조건 선호. 박지훈 고객의 K5 견적 조건 참고 가능."
                                                           Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="2026-07-06 11:05" Style="{StaticResource MutedText}" />
                                            <TextBlock Text="회사 DB에서 문의 확인. K5 하이브리드와 쏘나타를 비교 중."
                                                       Margin="0,5,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="SidebarPanel"
                    Grid.Column="4"
                    Style="{StaticResource Panel}"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="190" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="파일" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="견적 이미지를 선택하면 아래에 미리 표시됩니다."
                                       Style="{StaticResource MutedText}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="추가"
                                Style="{StaticResource ToolbarButton}"
                                VerticalAlignment="Top" />
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border x:Name="PreviewVisual"
                                    Background="#DBEAFE"
                                    BorderBrush="#93C5FD"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <Grid>
                                    <TextBlock Text="견적 이미지"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#1D4ED8"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                <TextBlock x:Name="PreviewTitle"
                                           Text="estimate_20260707_k5.png"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="PreviewMeta"
                                           Text="K5 하이브리드 · 월 498,000원 · 안내완료"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="파일 목록" Style="{StaticResource SectionTitle}" />
                        <ListBox x:Name="FileList"
                                 Grid.Row="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectedIndex="0"
                                 SelectionChanged="FileList_SelectionChanged"
                                 ItemContainerStyle="{StaticResource FileItem}">
                            <ListBoxItem Tag="estimate_20260707_k5.png|K5 하이브리드 · 월 498,000원 · 안내완료|Estimate">
                                <Border Background="{StaticResource SoftAccentBrush}" BorderBrush="#BBD1FF" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="estimate_20260707_k5.png" FontWeight="SemiBold" />
                                        <TextBlock Text="K5 하이브리드 · 월 498,000원" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                            </ListBoxItem>
                            <ListBoxItem Tag="estimate_20260706_k5_lowdown.jpg|K5 · 초기비용 낮은 조건 · 참고용|Estimate">
                                <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="estimate_20260706_k5_lowdown.jpg" FontWeight="SemiBold" />
                                        <TextBlock Text="박지훈 고객 유사 조건" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                            </ListBoxItem>
                            <ListBoxItem Tag="license_kim.jpg|면허증 이미지 · 첨부파일|Attachment">
                                <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="license_kim.jpg" FontWeight="SemiBold" />
                                        <TextBlock Text="면허증 이미지" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                            </ListBoxItem>
                            <ListBoxItem Tag="contract_draft.pdf|계약서 초안 · PDF 문서|Attachment">
                                <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="contract_draft.pdf" FontWeight="SemiBold" />
                                        <TextBlock Text="계약 관련 첨부" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                            </ListBoxItem>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
