<Window x:Class="ConsultNote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Consult Note"
        MinHeight="720"
        MinWidth="1180"
        Height="780"
        Width="1320"
        Background="#F5F7FA"
        FontFamily="Segoe UI, Malgun Gothic">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D7DEE8" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#172033" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="SoftAccentBrush" Color="#EAF1FF" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ProminentToggleButton" TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomerItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="FileItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <DataTemplate x:Key="CustomerTemplate">
            <Border Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" />
                            <TextBlock Text="{Binding StatusText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="8,2,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding RecentText}"
                                   Style="{StaticResource MutedText}" />
                    </Grid>
                    <TextBlock Text="{Binding ContactDetail}" Margin="0,5,0,0" />
                    <TextBlock Text="{Binding MemoPreview}"
                               Style="{StaticResource MutedText}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ConsultationLogTemplate">
            <Border BorderBrush="#E2E8F0"
                    BorderThickness="0,0,0,1"
                    Padding="0,0,0,12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{Binding CreatedAtText}" Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding Content}" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FileTemplate">
            <Border Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Summary}"
                               Style="{StaticResource MutedText}"
                               Margin="0,3,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource Panel}"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,18,0">
                    <TextBlock Text="Consult Note" FontSize="21" FontWeight="Bold" />
                    <TextBlock Text="상담 기록과 견적 파일을 빠르게 찾는 개인 작업대"
                               Style="{StaticResource MutedText}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <TextBox Grid.Column="1"
                         Height="38"
                         Padding="12,8"
                         FontSize="14"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="#334155"
                         VerticalAlignment="Center" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <Button Content="고객 추가"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"
                            Click="AddCustomerButton_Click" />
                    <Button Content="차량 관리"
                            Style="{StaticResource ToolbarButton}"
                            Margin="0,0,8,0"
                            Click="VehicleManagementButton_Click" />
                    <Button x:Name="SidebarToggleButton"
                            Content="파일 닫기"
                            Style="{StaticResource ToolbarButton}"
                            Click="SidebarToggleButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition x:Name="SidebarColumn" Width="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Panel}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="86" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="고객 목록" Style="{StaticResource SectionTitle}" />
                        <ComboBox Grid.Column="1"
                                  Height="30"
                                  ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SelectedSortOption}" />
                        <ComboBox Grid.Column="3"
                                  Height="30"
                                  ItemsSource="{Binding SortDirections}"
                                  SelectedItem="{Binding SelectedSortDirection}" />
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="빠른 검색 결과" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SearchSummary}"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Customers}"
                             SelectedItem="{Binding SelectedCustomer}"
                             ItemTemplate="{StaticResource CustomerTemplate}"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource CustomerItem}" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Panel}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedCustomer.Name}" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="{Binding SelectedCustomer.StatusText}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="14"
                                           Margin="10,9,0,0" />
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedCustomer.HeaderDetail}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="고객 저장"
                                Style="{StaticResource ToolbarButton}"
                                VerticalAlignment="Top"
                                Command="{Binding SaveCustomerCommand}" />
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1.35*" />
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="1.6*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="이름" Style="{StaticResource MutedText}" />
                                <TextBox Text="{Binding CustomerNameInput, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,4"
                                         Margin="0,5,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0">
                                <TextBlock Text="연락처" Style="{StaticResource MutedText}" />
                                <TextBox Text="{Binding CustomerPhoneInput, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,4"
                                         Margin="0,5,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="8,0">
                                <TextBlock Text="관심 차량" Style="{StaticResource MutedText}" />
                                <ComboBox IsEditable="True"
                                          IsTextSearchEnabled="True"
                                          ItemsSource="{Binding CustomerVehicleNames}"
                                          Text="{Binding CustomerVehicleNameInput, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,5,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="8,0">
                                <TextBlock Text="상태" Style="{StaticResource MutedText}" />
                                <ComboBox ItemsSource="{Binding CustomerStatusOptions}"
                                          SelectedItem="{Binding SelectedCustomerStatus}"
                                          Margin="0,5,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="4" Margin="8,0,0,0">
                                <TextBlock Text="메모" Style="{StaticResource MutedText}" />
                                <TextBox Text="{Binding CustomerMemoInput, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,4"
                                         Margin="0,5,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#FBFCFE"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="상담 조건 양식" FontWeight="SemiBold" Margin="0,0,0,8" />

                                <StackPanel Grid.Row="1" Margin="2,0">
                                    <UniformGrid Columns="1" Margin="0,0,0,6">
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="렌트/리스" Style="{StaticResource MutedText}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <RadioButton x:Name="RentRadioButton" Content="렌트" GroupName="ContractType" IsChecked="True" Margin="0,0,14,0" />
                                                    <RadioButton x:Name="LeaseRadioButton" Content="리스" GroupName="ContractType" />
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="차량스팩" Style="{StaticResource MutedText}" />
                                                <Grid Margin="0,5,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="82" />
                                                        <ColumnDefinition Width="6" />
                                                        <ColumnDefinition Width="118" />
                                                        <ColumnDefinition Width="6" />
                                                        <ColumnDefinition Width="92" />
                                                        <ColumnDefinition Width="6" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox x:Name="VehicleBrandComboBox"
                                                              IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              ItemsSource="{Binding VehicleBrands}"
                                                              SelectedItem="{Binding SelectedVehicleBrand}" />
                                                    <ComboBox x:Name="VehicleNameComboBox"
                                                              Grid.Column="2"
                                                              IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              ItemsSource="{Binding VehicleNames}"
                                                              SelectedItem="{Binding SelectedVehicleName}" />
                                                    <ComboBox x:Name="FuelTypeComboBox"
                                                              Grid.Column="4"
                                                              IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              ItemsSource="{Binding FuelTypes}"
                                                              SelectedItem="{Binding SelectedFuelType}" />
                                                    <TextBox x:Name="VehicleDetailTextBox"
                                                             Grid.Column="6"
                                                             Text="상세 옵션"
                                                             Padding="8,4"
                                                             Foreground="{StaticResource MutedTextBrush}" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="계약기간" Style="{StaticResource MutedText}" />
                                                <ComboBox x:Name="ContractPeriodComboBox" SelectedIndex="2" Margin="0,5,0,0">
                                                    <ComboBoxItem Content="단기" />
                                                    <ComboBoxItem Content="36개월" />
                                                    <ComboBoxItem Content="48개월" />
                                                    <ComboBoxItem Content="60개월" />
                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="주행거리" Style="{StaticResource MutedText}" />
                                                <Grid Margin="0,5,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox x:Name="MileageComboBox"
                                                              SelectedIndex="2"
                                                              SelectionChanged="MileageComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="1만km" />
                                                        <ComboBoxItem Content="1.5만km" />
                                                        <ComboBoxItem Content="2만km" />
                                                        <ComboBoxItem Content="2.5만km" />
                                                        <ComboBoxItem Content="3만km" />
                                                        <ComboBoxItem Content="3.5만km" />
                                                        <ComboBoxItem Content="4만km" />
                                                        <ComboBoxItem Content="4.5만km" />
                                                        <ComboBoxItem Content="5만km" />
                                                        <ComboBoxItem Content="무제한" />
                                                        <ComboBoxItem Content="직접입력" />
                                                    </ComboBox>
                                                    <TextBox x:Name="MileageCustomTextBox"
                                                             Grid.Column="2"
                                                             Text=""
                                                             IsEnabled="False"
                                                             Padding="8,4"
                                                             Foreground="{StaticResource MutedTextBrush}"
                                                             ToolTip="직접입력 선택 시 0~5 사이, 소수점 1자리까지 입력"
                                                             GotFocus="MileageCustomTextBox_GotFocus"
                                                             LostFocus="MileageCustomTextBox_LostFocus" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="인도지역" Style="{StaticResource MutedText}" />
                                                <Grid Margin="0,5,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox x:Name="DeliveryRegionComboBox" SelectedIndex="0">
                                                        <ComboBoxItem Content="서울" />
                                                        <ComboBoxItem Content="경기" />
                                                        <ComboBoxItem Content="인천" />
                                                        <ComboBoxItem Content="부산" />
                                                        <ComboBoxItem Content="대구" />
                                                    </ComboBox>
                                                    <TextBox x:Name="DeliveryRegionDetailTextBox" Grid.Column="2" Padding="8,4" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="초기비용" Style="{StaticResource MutedText}" />
                                                <Grid Margin="0,5,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox x:Name="NoInitialCostCheckBox" Content="없음" VerticalAlignment="Center" />
                                                    <TextBox x:Name="PrepaymentTextBox" Grid.Column="2" Text="선납금" Padding="8,4" Foreground="{StaticResource MutedTextBrush}" />
                                                    <TextBox x:Name="DepositTextBox" Grid.Column="4" Text="보증금" Padding="8,4" Foreground="{StaticResource MutedTextBrush}" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="명의형태" Style="{StaticResource MutedText}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <RadioButton x:Name="PersonalOwnerRadioButton" Content="개인" GroupName="OwnerType" IsChecked="True" Margin="0,0,12,0" />
                                                    <RadioButton x:Name="SoleProprietorOwnerRadioButton" Content="개인사업자" GroupName="OwnerType" Margin="0,0,12,0" />
                                                    <RadioButton x:Name="CorporateOwnerRadioButton" Content="법인사업자" GroupName="OwnerType" />
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="사업업력 / 운전면허" Style="{StaticResource MutedText}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <ToggleButton x:Name="BusinessExperienceToggleButton"
                                                                  Content="사업업력 1년 이상"
                                                                  Style="{StaticResource ProminentToggleButton}"
                                                                  Margin="0,0,8,0" />
                                                    <ToggleButton x:Name="DriverLicenseToggleButton"
                                                                  Content="운전면허 1년 이상"
                                                                  Style="{StaticResource ProminentToggleButton}"
                                                                  IsChecked="True" />
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="실운전자" Style="{StaticResource MutedText}" />
                                                <TextBox x:Name="ActualDriverTextBox" Padding="8,4" Margin="0,5,0,0" />
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="보험연령" Style="{StaticResource MutedText}" />
                                                <ComboBox x:Name="InsuranceAgeComboBox" SelectedIndex="1" Margin="0,5,0,0">
                                                    <ComboBoxItem Content="21세 이상" />
                                                    <ComboBoxItem Content="26세 이상" />
                                                    <ComboBoxItem Content="35세 이상" />
                                                    <ComboBoxItem Content="70세 이상" />
                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="신용상태" Style="{StaticResource MutedText}" />
                                                <TextBox x:Name="CreditStatusTextBox" Padding="8,4" Margin="0,5,0,0" />
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="특이사항" Style="{StaticResource MutedText}" />
                                                <TextBox x:Name="SpecialNoteTextBox" Padding="8,4" Margin="0,5,0,0" />
                                            </StackPanel>
                                    </UniformGrid>
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,4,0,0">
                                    <Button Content="저장"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,8,0"
                                            Click="ConditionFormSaveButton_Click" />
                                    <Button Content="첫통화 양식 복사"
                                            Style="{StaticResource ToolbarButton}"
                                            Click="ConsultationExportButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="#FFFFFF"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="상담 기록 쓰레드" Style="{StaticResource SectionTitle}" />
                                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                    <TextBlock Text="상담내역" Style="{StaticResource MutedText}" />
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ConsultationContentTextBox"
                                                 MinHeight="58"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Padding="8,6" />
                                        <Button Grid.Column="2"
                                                Content="상담 저장"
                                                Style="{StaticResource PrimaryButton}"
                                                VerticalAlignment="Top"
                                                Click="ConsultationLogSaveButton_Click" />
                                    </Grid>
                                </StackPanel>
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SelectedCustomer.ConsultationLogs}"
                                                  ItemTemplate="{StaticResource ConsultationLogTemplate}" />
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="SidebarPanel"
                    Grid.Column="4"
                    Style="{StaticResource Panel}"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="190" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="파일" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="견적 이미지를 선택하면 아래에 미리 표시됩니다."
                                       Style="{StaticResource MutedText}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="추가"
                                Style="{StaticResource ToolbarButton}"
                                VerticalAlignment="Top"
                                Click="AddCustomerFileButton_Click" />
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Background="#DBEAFE"
                                    BorderBrush="#93C5FD"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <Grid>
                                    <Image x:Name="SelectedFilePreviewImage"
                                           Stretch="Uniform"
                                           Visibility="Collapsed" />
                                    <TextBlock x:Name="SelectedFilePreviewLabel"
                                               Text="{Binding SelectedFile.PreviewLabel}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#1D4ED8"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                <TextBlock Text="{Binding SelectedFile.PreviewTitle}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedFile.PreviewMeta}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="파일 목록" Style="{StaticResource SectionTitle}" />
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding SelectedCustomer.Files}"
                                 SelectedItem="{Binding SelectedFile}"
                                 ItemTemplate="{StaticResource FileTemplate}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 MouseDoubleClick="FileListBox_MouseDoubleClick"
                                 ItemContainerStyle="{StaticResource FileItem}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
